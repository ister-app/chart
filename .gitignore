# Your real production values: hostnames, node names, paths. Keep them out of the repo.
# Start from values-production.example.yaml.
values-production.yaml

# Local tooling config (contains absolute paths).
.claude/

# Pulled by `helm dependency build`.
charts/

# Build artefacts of `helm package` and ci/release-notes.sh. CHANGELOG.md is committed,
# RELEASE_NOTES.md is only ever handed to `gh release create`.
*.tgz
RELEASE_NOTES.md

# Built by ci/build-docs.sh; attached to the GitHub Release, never committed.
ister-chart-docs-*.zip

# Rendered manifests the CI kubeconform step feeds to the container.
kubeconform-manifests.yaml
